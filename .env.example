# Database
DATABASE_URL="file:./db/custom.db"

# AI provider (ZAI / BigModel — OpenAI-compatible)
ZAI_API_KEY="your-zai-api-key-here"
ZAI_MODEL="glm-4.5-flash"
ZAI_ENDPOINT="https://open.bigmodel.cn/api/paas/v4/chat/completions"

# JWT secret — generate a long random string (>=32 chars)
# Example: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# App URL (used in email/SMS links)
APP_URL="http://localhost:3000"

# Email (optional — only if you wire up SMTP)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# SMS (optional — Iranian MeliPayamak)
# MELIPAYAMAK_USERNAME=""
# MELIPAYAMAK_PASSWORD=""
# MELIPAYAMAK_SENDER=""
